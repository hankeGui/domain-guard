# =========================================================
# domain-guard demo — environment file
#
# Copy this file to .env and fill in ONE of the API keys.
# If you leave both blank, the demo runs in MOCK mode — no
# network calls, no API key needed; canned responses with
# realistic timing and the real guard/agent/tool flow.
# =========================================================

# ---- Pick exactly one provider, or set LLM_PROVIDER explicitly ----

# Option 1: Anthropic Claude (recommended — cheap & fast with claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Option 2: OpenAI (gpt-4o-mini is fine)
OPENAI_API_KEY=

# Optional overrides:
# LLM_PROVIDER=mock         # force mock mode even with keys present
# LLM_PROVIDER=claude       # force claude
# LLM_PROVIDER=openai       # force openai
# LLM_MODEL=claude-haiku-4-5
# LLM_MODEL=gpt-4o-mini

# ---- Demo server ----

DEMO_PORT=9000
