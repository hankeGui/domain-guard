# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual envs
.venv/
venv/
env/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Editor temporary backup files
*~

# Local guard configs that should not ship
local_guards/

# Hot-reload cache, ad-hoc logs
*.log
/tmp/

# Avoid committing the downloaded sentence-transformers cache
.cache/huggingface/
